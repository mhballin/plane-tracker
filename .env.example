# .env.example
# Copy this file to .env and fill in your actual values.
# .env is git-ignored and will NOT be committed to the repository.
# This file IS committed so that cloners know what variables to set.

# ========================================
# Wi-Fi Configuration
# ========================================
WIFI_SSID=YOUR_WIFI_SSID
WIFI_PASSWORD=YOUR_WIFI_PASSWORD

# ========================================
# OpenWeather API
# ========================================
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY
WEATHER_CITY=Portland,US

# ========================================
# OpenSky Network (OAuth2 Client Credentials)
# ========================================
OPENSKY_CLIENT_ID=your-opensky-client-id
OPENSKY_CLIENT_SECRET=your-opensky-client-secret

# ========================================
# Home Location (Latitude / Longitude)
# ========================================
# Use decimal degrees. Example: Portland, ME is 43.6591, -70.2568
HOME_LAT=43.6591
HOME_LON=-70.2568
